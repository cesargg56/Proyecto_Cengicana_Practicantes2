<sql_create_table>CREATE TABLE `tbl_solicitud_prestamo` (
  `id_solicitud_prestamo` int(11) NOT NULL AUTO_INCREMENT,
  `cantidad` decimal(8,2) NOT NULL,
  `plazo` varchar(20) NOT NULL,
  `fecha_solicitud` datetime NOT NULL,
  `estado` int(2) NOT NULL,
  `id_clientes` int(11) NOT NULL,
  PRIMARY KEY (`id_solicitud_prestamo`),
  KEY `FK_tbl_solicitud_prestamo` (`id_clientes`),
  CONSTRAINT `FK_tbl_solicitud_prestamo` FOREIGN KEY (`id_clientes`) REFERENCES `tbl_clientes` (`id_clientes`)
) ENGINE=InnoDB AUTO_INCREMENT=10 DEFAULT CHARSET=utf8</sql_create_table>

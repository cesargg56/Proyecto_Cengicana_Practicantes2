<table name="tbl_clientes" view="colnames">
<left>18</left>
<top>256</top>
<width>105</width>
<height>180</height>
<sql_create_table>CREATE TABLE `tbl_clientes` (
  `id_clientes` int(11) NOT NULL AUTO_INCREMENT,
  `nombre` varchar(50) NOT NULL,
  `direccion` varchar(50) NOT NULL,
  `telefono` varchar(50) NOT NULL,
  `dpi` varchar(30) NOT NULL,
  `estado` int(11) NOT NULL,
  PRIMARY KEY (`id_clientes`),
  UNIQUE KEY `index_dpi` (`dpi`)
) ENGINE=InnoDB AUTO_INCREMENT=7 DEFAULT CHARSET=utf8</sql_create_table>
</table>
<table name="tbl_cuentas" view="colnames">
<left>596</left>
<top>226</top>
<width>112</width>
<height>163</height>
<sql_create_table>CREATE TABLE `tbl_cuentas` (
  `id_cuenta` int(11) NOT NULL AUTO_INCREMENT,
  `no_cuenta` varchar(50) NOT NULL,
  `estado` varchar(15) NOT NULL,
  `tipo_cuenta` varchar(20) NOT NULL,
  `id_clientes` int(11) NOT NULL,
  PRIMARY KEY (`id_cuenta`),
  KEY `FK_tbl_cuentas` (`id_clientes`),
  CONSTRAINT `FK_tbl_cuentas` FOREIGN KEY (`id_clientes`) REFERENCES `tbl_clientes` (`id_clientes`)
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8</sql_create_table>
</table>
<table name="tbl_solicitudes" view="colnames">
<left>795</left>
<top>7</top>
<width>130</width>
<height>180</height>
<sql_create_table>CREATE TABLE `tbl_solicitudes` (
  `id_solicitud` int(11) NOT NULL AUTO_INCREMENT,
  `servicio` varchar(50) NOT NULL,
  `fecha_solicitud` datetime NOT NULL,
  `fecha_entrega` datetime NOT NULL,
  `estado` varchar(20) NOT NULL,
  `id_cuenta` int(11) NOT NULL,
  PRIMARY KEY (`id_solicitud`),
  KEY `FK_tbl_solicitudes` (`id_cuenta`),
  CONSTRAINT `FK_tbl_solicitudes` FOREIGN KEY (`id_cuenta`) REFERENCES `tbl_cuentas` (`id_cuenta`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8</sql_create_table>
</table>
<table name="tbl_transacciones" view="colnames">
<left>836</left>
<top>240</top>
<width>149</width>
<height>163</height>
<sql_create_table>CREATE TABLE `tbl_transacciones` (
  `id_transaccion` int(11) NOT NULL AUTO_INCREMENT,
  `fecha_transaccion` datetime NOT NULL,
  `tipo_transaccion` varchar(20) NOT NULL,
  `cantidad` decimal(8,2) NOT NULL,
  `id_cuenta` int(11) NOT NULL,
  PRIMARY KEY (`id_transaccion`),
  KEY `FK_tbl_transacciones` (`id_cuenta`),
  CONSTRAINT `FK_tbl_transacciones` FOREIGN KEY (`id_cuenta`) REFERENCES `tbl_cuentas` (`id_cuenta`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8</sql_create_table>
</table>

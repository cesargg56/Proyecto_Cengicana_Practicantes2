<sql_create_table>CREATE TABLE `tbl_creditos` (
  `id_creditos` int(11) NOT NULL AUTO_INCREMENT,
  `saldo` decimal(8,2) NOT NULL,
  `estado` int(2) NOT NULL,
  `id_solicitud_prestamo` int(11) NOT NULL,
  `id_cuenta` int(11) NOT NULL,
  PRIMARY KEY (`id_creditos`),
  KEY `FK_tbl_prestamos` (`id_cuenta`),
  KEY `FK_tbl_creditos` (`id_solicitud_prestamo`),
  CONSTRAINT `FK_tbl_creditos` FOREIGN KEY (`id_solicitud_prestamo`) REFERENCES `tbl_solicitud_prestamo` (`id_solicitud_prestamo`),
  CONSTRAINT `FK_tbl_prestamos` FOREIGN KEY (`id_cuenta`) REFERENCES `tbl_cuentas` (`id_cuenta`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8</sql_create_table>
